<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.10" />
    <PackageReference Include="SQLitePCLRaw.lib.e_sqlite3" Version="2.1.12" />
  </ItemGroup>

  <!-- Linked rather than copied: the challenge dataset stays the single
       source of truth at its original path, and travels with the build. -->
  <ItemGroup>
    <Content Include="..\data\vehicles.json" Link="data\vehicles.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
